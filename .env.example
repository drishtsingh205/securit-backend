# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_BASE_URL=https://api.privacylens.io/v1

# ─── PostgreSQL ───────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=privacylens
POSTGRES_USER=privacylens
POSTGRES_PASSWORD=change_me_in_production

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_at_least_64_chars
JWT_ACCESS_EXPIRY=86400
JWT_REFRESH_EXPIRY=604800

# ─── Kafka ────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=privacylens-api

# ─── MinIO ────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=privacylens-reports
MINIO_USE_SSL=false

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Logging ─────────────────────────────────────────
LOG_LEVEL=info
